{
  "name": "@api-diff/cli",
  "version": "0.1.0",
  "description": "CLI for semantic API response and payload diffs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/api-diff/api-response-and-payload-diff-engine.git",
